#include <stdio.h>

int main() {
    int n, key, found = 0;

    // Read size
    scanf("%d", &n);

    int a[n];

    // Read elements
    for (int i = 0; i < n; i++) {
        scanf("%d", &a[i]);
    }

    // Read key
    scanf("%d", &key);

    // Linear search
    for (int i = 0; i < n; i++) {
        if (a[i] == key) {
            printf("found at position %d\n", i);
            found = 1;
            break;
        }
    }

    // If not found
    if (!found) {
        printf("%d not found\n", key);
    }

    return 0;
}
